{
  "name": "@cubee_ee/sdk",
  "version": "0.2.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "Cube DEX SDK — client library for interacting with the Cubic Pool AMM on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "env:mainnet": "cp .env.mainnet .env && echo 'Active env: MAINNET'",
    "env:testnet": "cp .env.testnet .env && echo 'Active env: TESTNET'",
    "env:show": "grep -E '^NETWORK=' .env || echo 'no .env'",
    "build": "tsc --declaration",
    "build:mainnet": "npm run env:mainnet && npm run build",
    "build:testnet": "npm run env:testnet && npm run build",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "solana",
    "dex",
    "amm",
    "cube",
    "sdk"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
