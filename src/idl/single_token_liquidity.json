          "writable": true
        },
        {
          "name": "helper"
        },
        {
          "name": "bpt_mint",
          "writable": true
        },
        {
          "name": "helper_bpt_account",
          "docs": [
            "Helper's BPT account (where the freshly-minted BPT lands before",
            "being forwarded to the user)."
