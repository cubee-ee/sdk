    {
      "name": "Treasury",
      "docs": [
        "Singleton governance account at PDA `[b\"treasury\"]`. Holds the human",
        "admin pubkey, a list of registered token mints + vault addresses, and",
        "pending-admin state for the 2-step transfer flow."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "admin",
            "docs": [
              "Pubkey allowed to call every admin wrapper below."
            ],
            "type": "pubkey"
          },
          {
            "name": "pending_admin",
            "docs": [
              "Pending admin during a 2-step transfer; `Pubkey::default()` when",
              "no transfer is in flight."
            ],
            "type": "pubkey"
          },
          {
            "name": "bump",
            "docs": [
              "Bump seed for the treasury PDA."
            ],
            "type": "u8"
          },
          {
            "name": "token_count",
            "docs": [
              "Active count of `token_mints` / `token_vaults`."
            ],
            "type": "u8"
          },
          {
            "name": "token_mints",
            "docs": [
              "Registered token mints (index-aligned with `token_vaults`)."
            ],
            "type": {
              "array": [
                "pubkey",
                10
              ]
            }
          },
          {
            "name": "token_vaults",
            "docs": [
              "Treasury-owned vault accounts (PDA `[b\"vault\", mint]`)."
            ],
            "type": {
              "array": [
                "pubkey",
                10
              ]
            }
          },
          {
            "name": "created_at",
            "docs": [
              "Creation `Clock::unix_timestamp`."
            ],
            "type": "i64"
          },
          {
            "name": "reserved",
            "docs": [
              "Padding for forward-compat fields."
            ],
            "type": {
              "array": [
                "u8",
                64
              ]
            }
          }
        ]
      }
    },
